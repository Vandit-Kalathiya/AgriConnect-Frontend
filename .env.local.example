# Local Development Environment Variables
# Copy this file to .env.local and modify as needed
# .env.local is gitignored and won't be committed

# ============================================
# QUICK START: Disable Notifications Locally
# ============================================
# Uncomment these lines to disable notifications in your local environment:

# VITE_ENABLE_NOTIFICATIONS=false
# VITE_ENABLE_WEBSOCKET=false

# ============================================
# OR: Enable Notifications (Default)
# ============================================
# VITE_ENABLE_NOTIFICATIONS=true
# VITE_ENABLE_WEBSOCKET=true

# ============================================
# Other Local Overrides
# ============================================
# VITE_API_GATEWAY_URL=http://localhost:8080
